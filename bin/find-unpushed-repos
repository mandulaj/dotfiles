#!/bin/bash


DIR=${1:-./}

# help message
if [ "$1" == "-h" ] || [ "$1" == "--help" ]; then
    echo "Usage: $0 [directory]"
    echo "Find git repositories (to a depth of 8) with unpushed commits in the specified directory (default: current directory)."
    exit 0
fi

if [ ! -d "$DIR" ]; then
    echo "Error: $DIR is not a directory."
    exit 1
fi


# This script lists all git repositories in the current directory
# that have unpushed commits.


find $DIR -maxdepth 8 -type d -name .git -exec dirname {} \; | while read LINE; do
    ( # start subshell
        cd "$LINE" && \
        result=`git cherry -v 2>/dev/null`; rc=$? && \

        # if the stdout of git-cherry is not an empty string
        if [ -n "$result" ]; then
            echo $(pwd)
        fi
    ) # end subshell
done
